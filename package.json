{
  "name": "@prospeo/prospeo-mcp-server",
  "version": "1.0.0",
  "description": "Prospeo MCP server - Find people and company data and enrich them with verified emails and mobile numbers.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "prospeo-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:http": "tsc -p tsconfig.http.json",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http-server.ts",
    "start": "node dist/index.js",
    "start:http": "node dist-http/http-server.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "prospeo",
    "sales",
    "marketing",
    "lead-enrichment",
    "leads",
    "b2b",
    "data-enrichment",
    "company-data",
    "email-finder",
    "contact-data"
  ],
  "author": {
    "name": "Apoorva Pandey",
    "email": "apoorva@prospeo.io"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0",
    "zod-to-json-schema": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jose": "^6.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/prospeo-v2/prospeo-mcp-server"
  },
  "publishConfig": {
    "access": "public"
  }
}
